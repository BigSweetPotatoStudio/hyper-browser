{
  "name": "hyper-browser-companion-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:chrome": "wxt -b chrome",
    "dev:firefox": "wxt -b firefox --mv3",
    "build": "pnpm run build:chrome && pnpm run build:firefox",
    "build:chrome": "wxt build -b chrome",
    "build:firefox": "wxt build -b firefox --mv3",
    "zip": "pnpm run zip:chrome && pnpm run zip:firefox",
    "zip:chrome": "wxt zip -b chrome",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "typecheck": "wxt prepare && tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.8",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "wxt": "^0.20.26"
  },
  "pnpm": {
    "allowBuilds": {
      "esbuild": true,
      "spawn-sync": true
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "spawn-sync"
    ]
  }
}
