{
  "manifest_version": 2,
  "name": "Hyper Browser Internal Pages",
  "version": "1.24",
  "browser_specific_settings": {
    "gecko": {
      "id": "hyper-browser-internal@dadigua.com"
    }
  },
  "permissions": [
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js",
      "site-compat/x-prelude-worker-fallback.js",
      "site-compat/index.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "scroll-restoration-content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "pull-refresh-content.js",
        "ime-focus-reveal-content.js",
        "media-keepalive-content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "background-video-enhancement-content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
